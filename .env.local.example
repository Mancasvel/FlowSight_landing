# FlowSight PM Dashboard - Environment Variables
# Copy this file to .env.local and fill in your values.
# Never commit .env.local (gitignore should exclude it).

# =============================================================================
# SUPABASE: LOCAL / STAGING VS PRODUCTION
# =============================================================================
# Goal: run `npm run dev` against a TEST Supabase project (clone or empty dev
# project) and leave production credentials only on Vercel/hosting.
#
# Full database copy (schema + data + auth users) — official way:
#   Supabase Dashboard → your PRODUCTION project → Database → Backups →
#   "Restore to a new project" (paid plan + physical backups enabled).
#   Docs: https://supabase.com/docs/guides/platform/clone-project
#   After it finishes, open the NEW project → Settings → API and copy URL +
#   anon + service role secret into YOUR local .env.local only.
#
# Branching (schema + migrations only, NOT a data copy):
#   Dashboard → Branches. Useful for migrations, not for cloning prod rows.
#
# Current production project ref (public in URLs; do not put secret keys here):
#   dzpyrdxelcgfpmcdojvb  (region eu-west-1)
#
# In .env.local for daily development, put ONLY the staging/clone project values:

# =============================================================================
# SUPABASE CONFIGURATION (use STAGING / CLONE values in .env.local for dev)
# =============================================================================
# Get these from: https://supabase.com/dashboard/project/_/settings/api

# Staging or clone project URL (NOT production if you want a safe sandbox)
NEXT_PUBLIC_SUPABASE_URL=https://your-staging-project-ref.supabase.co

# Staging anon/public key (safe for browser)
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Staging server-only secret key (API routes / worker delete). NOT the publishable key.
SUPABASE_SECRET_KEY=sb_secret_xxx

# =============================================================================
# GOOGLE OAUTH (configured in Supabase Dashboard)
# =============================================================================
# 1. Go to Supabase Dashboard → Authentication → Providers → Google
# 2. Enable Google provider
# 3. Add your Google OAuth credentials (from Google Cloud Console)
# 4. Set redirect URL to: http://localhost:3000/auth/callback

# =============================================================================
# STRIPE CONFIGURATION (Payments & Licenses) — LIVE MODE
# =============================================================================
# Production keys: https://dashboard.stripe.com/apikeys
# Live webhook endpoint: https://flowsight.site/api/webhooks/stripe
# Create webhook in Stripe Dashboard → Developers → Webhooks (Live mode)
# Events: checkout.session.completed, invoice.payment_succeeded

STRIPE_SECRET_KEY=sk_live_51...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_51...
STRIPE_WEBHOOK_SECRET=whsec_...

# Live Price IDs (Stripe Dashboard → Products → each plan → Pricing → Price ID)
NEXT_PUBLIC_STRIPE_PRICE_INDIVIDUAL_PRO=price_
NEXT_PUBLIC_STRIPE_PRICE_TEAMS_SIMPLE=price_
NEXT_PUBLIC_STRIPE_PRICE_TEAMS_PRO=price_
NEXT_PUBLIC_STRIPE_PRICE_ENTERPRISE=price_

# =============================================================================
# APP CONFIGURATION
# =============================================================================
NEXT_PUBLIC_APP_URL=http://localhost:3000

# =============================================================================
# MONGODB ATLAS (landing analytics, newsletter, macOS waitlist)
# =============================================================================
# Get connection string from: https://cloud.mongodb.com → Connect → Drivers
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/flowsight?retryWrites=true&w=majority

# Bearer token to read aggregated download click counts (GET /api/analytics/summary)
ANALYTICS_READ_SECRET=your-random-secret-here

# =============================================================================
# PRO PLANS — AI COACH (Azure OpenAI) + ENCRYPTED DIGESTS
# =============================================================================
# Generate ENCRYPTION_KEY: openssl rand -base64 32
# Used for AES-256-GCM at rest (digest recipients, report audit logs)
ENCRYPTION_KEY=

# Azure OpenAI — Mistral-Large-3 (Deployments + Endpoint in Azure AI Foundry)
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=https://france-flow.services.ai.azure.com/openai/v1/
AZURE_OPENAI_DEPLOYMENT=Mistral-Large-3
# Optional alias: AZURE_OPENAI_MODEL=Mistral-Large-3
# Embeddings for coach document context (deploy text-embedding-3-small in Azure AI Foundry)
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-small

# Weekly report emails (Resend)
RESEND_API_KEY=
RESEND_FROM_EMAIL=FlowSight Reports <reports@flowsight.site>

# Cron auth (Vercel Cron sends Authorization: Bearer <CRON_SECRET>)
CRON_SECRET=

# =============================================================================
# AI COACH API PROTECTION (antibot + same-origin enforcement)
# =============================================================================
# Cloudflare Turnstile — https://dash.cloudflare.com/?to=/:account/turnstile
# If TURNSTILE_SECRET_KEY is unset, bot checks are skipped (dev only).
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Comma-separated allowed origins for coach API (defaults include NEXT_PUBLIC_APP_URL)
# COACH_API_ALLOWED_ORIGINS=https://flowsight.site,https://www.flowsight.site

# Local dev only — skip origin/client header checks (never enable in production)
# COACH_API_SKIP_ORIGIN_CHECK=true
# COACH_API_SKIP_CLIENT_HEADER=true

